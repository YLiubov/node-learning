generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Car {
  id Int @id @default(autoincrement())

  brandId    Int
  categoryId Int
  fueltypeId Int

  model String
  year  Int
  price Float

  brand    Brand    @relation(fields: [brandId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])
  fueltype Fueltype @relation(fields: [fueltypeId], references: [id])

  @@map("cars")
}

model Brand {
  id Int @id @default(autoincrement())

  name    String
  logoUrl String?

  cars Car[]

  @@map("brands")
}

model Category {
  id Int @id @default(autoincrement())

  name String

  cars Car[]

  @@map("categories")
}

model Fueltype {
  id Int @id @default(autoincrement())

  name String

  cars Car[]

  @@map("fueltypes")
}

enum Role {
  USER
  ADMIN
}

model User {
  id Int @id @default(autoincrement())

  firstname String
  lastname  String
  email     String  @unique
  password  String
  role      Role    @default(USER)
  isActive  Boolean @default(true)

  @@map("users")
}
