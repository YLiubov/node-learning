// This is your Prisma schema file
// Learn more about Prisma here: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Car {
  id       Int    @id @default(autoincrement())
  category String
  brand    String
  model    String
  year     Int
  price    Float
  fueltype String

  @@map("cars")
}

model Category {
  id   Int    @id @default(autoincrement())
  name String

  @@map("categories")
}

model Brand {
  id   Int    @id @default(autoincrement())
  name String
  logo String

  @@map("brands")
}